services:
  stalwart:
    image: stalwartlabs/stalwart:latest
    container_name: stalwart-mail
    ports:
      - "25:25"      # SMTP
      - "587:587"    # Submission
      - "465:465"    # SMTPS
      - "143:143"    # IMAP
      - "993:993"    # IMAPS
      - "4190:4190"  # ManageSieve
      - "110:110"    # POP3
      - "995:995"    # POP3S
      - "8080:8080"  # Web admin UI (initial access)
      # - "443:443"  # ← Comment this out if it conflicts with Coolify Traefik
    volumes:
      - stalwart-data:/opt/stalwart
    restart: always
    tty: true
    stdin_open: true

volumes:
  stalwart-data: